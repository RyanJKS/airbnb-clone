{
  "name": "@airbnb-clone/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync": "uv sync",
    "lock": "uv lock",
    "dev": "uv run python manage.py runserver 0.0.0.0:8000",
    "build": "uv run python -m compileall config chat property useraccount manage.py",
    "check": "uv run python manage.py check",
    "migrate": "uv run python manage.py migrate",
    "makemigrations": "uv run python manage.py makemigrations",
    "test": "uv run python manage.py test"
  }
}
